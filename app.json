{
  "expo": {
    "name": "Ritmo",
    "slug": "Ritmo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ritmo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/branding/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.locione.ritmo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.locione.ritmo"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withRitmoWidgetNative",
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.locione.ritmo",
          "widgets": [
            {
              "name": "RitmoTodayWidget",
              "displayName": "Ritmo — Hoje",
              "description": "Resumo do seu dia no Ritmo",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "RitmoNextWidget",
              "displayName": "Ritmo — Próximo",
              "description": "Seu próximo compromisso",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.locione.ritmo.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.locione.ritmo"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "3d894c48-b86a-4b48-b6dd-1767f53af295"
      }
    }
  }
}
